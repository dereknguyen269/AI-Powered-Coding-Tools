{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^http://127.0.0.1"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "^#"
    },
    {
      "pattern": "^https://img.shields.io"
    },
    {
      "pattern": "^https://shields.io"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "https://github.com/dereknguyen269/AI-Powered-Coding-Tools/blob/main/"
    }
  ],
  "aliveStatusCodes": [200, 206, 403, 429],
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "timeout": "20s",
  "verbose": false,
  "concurrency": 5
}